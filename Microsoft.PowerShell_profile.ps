# (Do Git Stuff) Git commit - stage all, show status, commit with message
function dgs {
    git add -A
    git status
    git commit -m "$args"
}

# Git reset - undo last commit (keeps changes staged)
function gr {
    git reset HEAD~1
}

# Git switch branch develop - switch to develop branch
function gswbd {
    git switch develop
}

# Git switch - switch to existing branch
function gswb {
    param([string]$branch)
    git switch $branch
}

# Git switch create - create and switch to new branch
function gswbc {
    param([string]$branch)
    git switch -c $branch
}

# Git merge branch - fetch, pull all, then merge specified or develop branch
function gmb {
    param([string]$branch)

    git fetch origin
    git pull --all

    if ($branch) {
        git merge $branch
    } else {
        git merge origin/develop
    }
}

# Git commit - commit with message
function gicm {
    param(
        [Parameter(ValueFromRemainingArguments = $true)]
        [string[]]$message
    )

    $commitMessage = $message -join " "
    git commit -m "$commitMessage"
}

# Git status
function gst { git status }

# Git push
function gpu { git push }

# Git branch
function gb { git branch }

# Git fetch and pull
function gfp { git fetch; git pull }

# Git stash - stash all files (tracked + untracked) with optional message
function gstu {
    param(
        [Parameter(ValueFromRemainingArguments = $true)]
        [string[]]$message
    )
    
    $stashMessage = $message -join " "
    if ($stashMessage) {
        git stash push -u -m "$stashMessage"
    } else {
        git stash push -u
    }
}

# Git stash pop - apply latest stash and remove it from the stash list
function gstp {
    git stash pop
}

# Git stash list - show all stashes
function gstl {
    git stash list
}

# Git stash clear - remove all stashes
function gstc {
    git stash clear
}

# Git stash show - show changes in latest stash as a patch
function gsts {
    git stash show -p
}

# Git stash apply - apply latest stash without removing it from the stash list
function gsta {
    git stash apply
}

# Docker Compose up - start services in background
function dcu { docker compose up -d }

# Docker Compose down - stop and remove containers
function dcd { docker compose down }

# Docker Compose down - stop and remove containers and volumes
function dcdv { docker compose down -v }

# Docker Compose logs - view live logs from all services
function dcl { docker compose logs -f }

# Docker Compose Vendor up - start vendor services in background
function dcvu { docker compose -f docker-compose.vendor.yml up -d }

# Docker Compose Vendor down - stop and remove vendor containers
function dcvd { docker compose -f docker-compose.vendor.yml down }

# Docker Compose Vendor down - stop and remove vendor containers and volumes
function dcvdv { docker compose -f docker-compose.vendor.yml down -v }

# Docker Compose Vendor logs - view live logs from vendor services
function dcvl { docker compose -f docker-compose.vendor.yml logs -f }

# Flutter pub get - download and install dependencies
function fpg { flutter pub get }

# Flutter clean - delete build directory and artifacts
function flc { Invoke-Expression "flutter clean" }

# Flutter analyze - run static analysis on Dart code
function fa { flutter analyze }

# Flutter run optional environment - start the application with optional environment variable
function frev {
    param([string]$ENV)
    if ($ENV) {
        flutter run --dart-define=ENV=$ENV
    } else {
        flutter run
    }
}
# VS Code - open PowerShell profile in VS Code
function np { code $PROFILE }

# Clear - clear console screen
function c { clear }

# Dotnet run - start the application
function dr { 
    $projFile = Get-ChildItem -Filter "*.csproj" -File | Select-Object -First 1
    if ($projFile) {
        dotnet run --project $projFile.FullName
    } else {
        dotnet run
    }
}

# Dotnet EF - create migration with name
function dcm { dotnet ef migrations add $args }

# Dotnet EF - update database to latest migration
function dud { dotnet ef database update }

# Dotnet EF - remove last migration
function dmr { dotnet ef migrations remove }

# Dotnet EF - list all migrations
function dml { dotnet ef migrations list }

# Dotnet restore - automatically find .sln and restore
function dres { 
    $slnFile = Get-ChildItem -Filter "*.sln" -File | Select-Object -First 1
    if ($slnFile) {
        dotnet restore $slnFile.FullName
    } else {
        dotnet restore
    }
}

# Dotnet build - automatically find .sln and build
function dbu { 
    $slnFile = Get-ChildItem -Filter "*.sln" -File | Select-Object -First 1
    if ($slnFile) {
        dotnet build $slnFile.FullName
    }
}

# IP Config - show Wi-Fi IPv4 address only
function ip { 
    Get-NetIPAddress -AddressFamily IPv4 -InterfaceAlias "Wi-Fi" | Select-Object -ExpandProperty IPAddress
}

function db {
    $process = Get-Process dbeaver -ErrorAction SilentlyContinue
    if ($process) {
        # Bring existing window to front
        $hwnd = $process.MainWindowHandle
        Add-Type @"
            using System;
            using System.Runtime.InteropServices;
            public class Win32 {
                [DllImport("user32.dll")]
                public static extern bool SetForegroundWindow(IntPtr hWnd);
            }
"@
        [Win32]::SetForegroundWindow($hwnd) | Out-Null
    } else {
        Start-Process "C:\Users\EmircanDuman\AppData\Local\DBeaver\dbeaver.exe"
    }
}

# Update Profile - reload PowerShell profile
function up { . $PROFILE }
